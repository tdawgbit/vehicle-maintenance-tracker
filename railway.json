{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "pip install -r requirements.txt && cd vehicle_tracker && python manage.py collectstatic --noinput"
  },
  "deploy": {
    "preDeployCommand": "cd vehicle_tracker && python manage.py migrate",
    "startCommand": "cd vehicle_tracker && gunicorn vehicle_tracker.wsgi:application --bind 0.0.0.0:$PORT",
    "healthcheckPath": "/health/",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
